# ==============================================
# AtlasCloud 平台（适用于 seedance / wan / veo / kling-atlas）
# ==============================================
# 固定 API Key，从 AtlasCloud 控制台获取，长期有效
export VIDEO_API_KEY="your_atlascloud_api_key_here"
export VIDEO_API_URL="https://api.atlascloud.ai"


# ==============================================
# Kling 官方 API（仅 gen_kling_official.sh 使用）
# ==============================================
# 注意：VIDEO_API_KEY 由脚本自动从 AK/SK 生成 JWT token（24 小时有效），不需要手动填写
# 从 Kling 开放平台获得：https://console.klingai.com/
export KLING_ACCESS_KEY="your_kling_access_key_here"
export KLING_SECRET_KEY="your_kling_secret_key_here"